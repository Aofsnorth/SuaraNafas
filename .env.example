# Optional. When set, /api/analyze forwards audio files to the backend CNN service.
# If omitted, the route returns deterministic mock predictions for UI development.
BACKEND_API_URL=https://your-cnn-backend.example.com

# Firebase (email/password auth for the doctor-referral flow).
# Create a project at https://console.firebase.google.com, enable Email/Password
# under Authentication > Sign-in method, then copy the web app config below.
# If these are omitted, the referral login shows a graceful "not configured"
# state instead of crashing, so the rest of the demo keeps working.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
