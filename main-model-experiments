    "            c_start = int((c + yoho_preds[c, 1]) * cell_dur)\n",
    "            c_stop = int((c + yoho_preds[c, 2]) * cell_dur)\n",
    "            ax1.axvspan(c_start, c_stop, color='red', alpha=0.15, label='Cough' if c==0 else \"\")\n",
    "            ax1.axvline(c_start, color='red', linestyle='--', alpha=0.5)\n",
