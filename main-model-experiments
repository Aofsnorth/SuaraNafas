    "    fig.colorbar(img2, ax=ax2, label=\"Attention Weight\")\n",
    "    \n",
    "    # Subplot 3: ProtoPNet similarities\n",
    "    ax3 = fig.add_subplot(2, 2, 3)\n",
    "    proto_ids = [f\"Proto {i}\" for i in range(len(proto_sims))]\n",
